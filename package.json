{
  "name": "ai-book-tools",
  "version": "1.2.0",
  "description": "Static HTML/JavaScript tools for AI-assisted writing and book editing",
  "main": "index.html",
  "scripts": {
    "start": "python -m http.server 8000",
    "serve": "python -m http.server 8000",
    "lint": "htmlhint \"**/*.html\" || true",
    "lint:md": "markdownlint -c .markdownlint.jsonc -p .markdownlintignore \"**/*.md\"",
    "lint:js": "echo 'JavaScript linting not configured yet'",
    "test": "npm run lint && npm run validate-json",
    "test:governance": "node scripts/check-requirements-governance.js",
    "test:e2e": "playwright test",
    "test:e2e:novelwriter": "playwright test e2e/novelwriter.regression.spec.js",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:regression": "npm run test:governance && npm run test:e2e",
    "validate-json": "for file in $(find . -name \"*.json\" -not -path \"./node_modules/*\"); do jq empty \"$file\" || exit 1; done && echo 'All JSON valid'",
    "build": "echo 'No build step required - static files only'",
    "preview": "echo 'Open index.html in browser to preview'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bnorth12/AI-Book-Tools.git"
  },
  "keywords": [
    "writing",
    "ai",
    "novel",
    "book",
    "editor",
    "author",
    "creative-writing"
  ],
  "author": "bnorth12",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bnorth12/AI-Book-Tools/issues"
  },
  "homepage": "https://github.com/bnorth12/AI-Book-Tools#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "htmlhint": "^1.1.4",
    "markdownlint-cli": "^0.48.0"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ]
}
