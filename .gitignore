# Ignore OS files
.DS_Store
Thumbs.db

# Ignore editor files
*.swp
*.swo
*.tmp
*.bak

# Ignore local environment files
.env
npm-debug.log*

# Ignore application logs
*.log

# Ignore generated files
dist/
build/

# Node / Playwright
node_modules/
playwright-report/
test-results/

# IDE
.vs/

# Keep API keys out of version control
*.key
*.secret

# Session exports may contain API keys - never commit
*_session.json
